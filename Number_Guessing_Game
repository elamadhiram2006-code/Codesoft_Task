#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;
int main()
{
    int number, guess;
    srand(time(0));          
    number = rand() % 100 + 1; 
    while (true)
    {
        cout << "Enter a guess number: ";
        cin >> guess;
        if (number == guess)
        {
            cout << "You guessed it correct..." << endl;
            break;
        }
        else if (guess > number)
        {
            cout << "Too high" << endl;
        }
        else
        {
            cout << "Too low" << endl;
        }
    }

    return 0;
}
